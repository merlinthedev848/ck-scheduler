# CK Scheduler Environment Variables
# Copy this file to .env and fill in your values

# App
APP_NAME=CK Scheduler
APP_URL=http://localhost:3000
APP_PORT=3000
APP_SECRET=change_this_to_a_long_random_secret_string
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ck_scheduler
DB_USER=root
DB_PASSWORD=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM_NAME=CK Scheduler
MAIL_FROM_EMAIL=noreply@ckscheduler.com

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Session
SESSION_SECRET=change_this_to_another_long_random_string
SESSION_TIMEOUT_HOURS=8

# First Admin (used during installation/seed)
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_EMAIL=admin@ckscheduler.com
ADMIN_PASSWORD=admin123!
