extends ../layout

block content
  .row
    .col-md-3
      include _menu
    
    
    .col-md-9
      .card.shadow-sm
        .card-header.bg-white
          h5.m-0 API Access
        .card-body
          .alert.alert-info.mb-4
            i.bi.bi-info-circle-fill.me-2
            | Use this API token to authenticate requests to the REST API via the <code>X-Api-Key</code> header.
            
          .mb-4
            label.form-label Your Personal API Token
            .input-group
              input.form-control#apiToken(type="text" value=user.api_token readonly)
              button.btn.btn-outline-secondary(type="button" onclick="copyToken()")
                i.bi.bi-clipboard
                |  Copy
          
          hr.my-4
          
          h5 REST API Documentation
          p.text-muted Connect external applications to your scheduler using these endpoints.

          .accordion#apiDocs
            .accordion-item
              h2.accordion-header
                button.accordion-button.collapsed(type="button" data-bs-toggle="collapse" data-bs-target="#apiAuth") Authentication
              .accordion-collapse.collapse#apiAuth(data-bs-parent="#apiDocs")
                .accordion-body
                  p All requests to the API must include the <code>X-Api-Key</code> header.
                  pre.bg-light.p-3.rounded
                    code GET /api/v1/appointments
                    br
                    code X-Api-Key: #{user.api_token}
            
            .accordion-item
              h2.accordion-header
                button.accordion-button.collapsed(type="button" data-bs-toggle="collapse" data-bs-target="#apiEndpoints") Available Endpoints
              .accordion-collapse.collapse#apiEndpoints(data-bs-parent="#apiDocs")
                .accordion-body
                  table.table.table-sm
                    thead
                      tr
                        th Resource
                        th Endpoints
                    tbody
                      tr
                        td: strong Appointments
                        td
                          div <code>GET /api/v1/appointments</code> (list)
                          div <code>GET /api/v1/appointments/:id</code> (get one)
                          div <code>POST /api/v1/appointments</code> (create)
                          div <code>PUT /api/v1/appointments/:id</code> (update)
                          div <code>DELETE /api/v1/appointments/:id</code> (delete)
                      tr
                        td: strong Services
                        td
                          div <code>GET /api/v1/services</code> (list)
                          div <code>POST /api/v1/services</code> (create)
                      tr
                        td: strong Customers
                        td
                          div <code>GET /api/v1/customers</code> (list)
                          div <code>POST /api/v1/customers</code> (create)
                      tr
                        td: strong Providers
                        td
                          div <code>GET /api/v1/providers</code> (list)

          hr.my-5
          
          form(action="/settings/api/regenerate" method="POST" onsubmit="return confirm('Regenerating your token will invalidate any existing API integrations using the old token. Continue?');")
            h6.text-danger Danger Zone
            p.text-muted If you suspect your API token has been compromised, you can regenerate a new one.
            button.btn.btn-outline-danger(type="submit") Regenerate API Token

block scripts
  script.
    function copyToken() {
      var copyText = document.getElementById("apiToken");
      copyText.select();
      copyText.setSelectionRange(0, 99999);
      navigator.clipboard.writeText(copyText.value);
      alert("Token copied to clipboard!");
    }
