extends ../layout

block content
  .row
    .col-md-3
      .list-group.mb-4
        a.list-group-item.list-group-item-action.active(href="/settings/general") General
        a.list-group-item.list-group-item-action(href="/settings/business") Business Logic
        a.list-group-item.list-group-item-action(href="/settings/booking") Booking Page
        a.list-group-item.list-group-item-action(href="/settings/payments") Payments
        a.list-group-item.list-group-item-action(href="/settings/api") API Access
    
    .col-md-9
      .card.shadow-sm
        .card-header.bg-white
          h5.m-0 General Settings
        .card-body
          form(action="/settings/general" method="POST")
            .mb-3
              label.form-label Company Name
              input.form-control(type="text" name="company_name" value=settings.company_name)
            .mb-3
              label.form-label Company Email (for notifications)
              input.form-control(type="email" name="company_email" value=settings.company_email)
            .mb-3
              label.form-label Company Website Link
              input.form-control(type="url" name="company_link" value=settings.company_link placeholder="https://")
            button.btn.btn-primary(type="submit") Save Settings
