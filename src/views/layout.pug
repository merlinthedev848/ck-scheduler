doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title #{title}
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css")
    link(rel="stylesheet", href="/css/admin.css")
    block styles

  body.bg-light
    .d-flex.h-100.vh-100
      // Sidebar
      .sidebar.bg-dark.text-white.p-3.d-flex.flex-column
        a.d-flex.align-items-center.mb-3.mb-md-0.me-md-auto.text-white.text-decoration-none(href="/calendar")
          i.bi.bi-calendar2-check-fill.fs-4.me-2
          span.fs-4 CK Scheduler
        hr
        ul.nav.nav-pills.flex-column.mb-auto
          li.nav-item
            a.nav-link.text-white(href="/calendar" class=(path && path.startsWith('/calendar') ? 'active' : ''))
              i.bi.bi-calendar3.me-2
              | Calendar
          li
            a.nav-link.text-white(href="/appointments" class=(path && path.startsWith('/appointments') ? 'active' : ''))
              i.bi.bi-list-ul.me-2
              | Appointments
          li
            a.nav-link.text-white(href="/customers" class=(path && path.startsWith('/customers') ? 'active' : ''))
              i.bi.bi-people.me-2
              | Customers
          if session && session.user && session.user.role === 'admin'
            li
              a.nav-link.text-white(href="/services" class=(path && path.startsWith('/services') ? 'active' : ''))
                i.bi.bi-briefcase.me-2
                | Services
            li
              a.nav-link.text-white(href="/providers" class=(path && path.startsWith('/providers') ? 'active' : ''))
                i.bi.bi-person-badge.me-2
                | Providers
            li
              a.nav-link.text-white(href="/payments/history" class=(path && path.startsWith('/payments') ? 'active' : ''))
                i.bi.bi-credit-card.me-2
                | Payments
            li
              a.nav-link.text-white(href="/settings/general" class=(path && path.startsWith('/settings') ? 'active' : ''))
                i.bi.bi-gear.me-2
                | Settings

        hr
        .dropdown
          a.d-flex.align-items-center.text-white.text-decoration-none.dropdown-toggle(href="#" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false")
            i.bi.bi-person-circle.fs-4.me-2
            strong= (session && session.user ? session.user.first_name : 'User')
          ul.dropdown-menu.dropdown-menu-dark.text-small.shadow(aria-labelledby="dropdownUser1")
            li: a.dropdown-item(href="/logout") Sign out

      // Main content
      .content-wrapper.flex-grow-1.d-flex.flex-column.overflow-auto
        header.bg-white.shadow-sm.p-3.mb-4.d-flex.justify-content-between.align-items-center
          h4.m-0= title
          a.btn.btn-outline-primary.btn-sm(href="/" target="_blank") View Booking Page <i class="bi bi-box-arrow-up-right ms-1"></i>

        main.container-fluid.px-4.pb-4.flex-grow-1
          if messages && messages.success && messages.success.length > 0
            .alert.alert-success.alert-dismissible.fade.show
              each msg in messages.success
                div= msg
              button.btn-close(data-bs-dismiss="alert")
          
          if messages && messages.error && messages.error.length > 0
            .alert.alert-danger.alert-dismissible.fade.show
              each msg in messages.error
                div= msg
              button.btn-close(data-bs-dismiss="alert")

          block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")
    script(src="/js/admin.js")
    block scripts
