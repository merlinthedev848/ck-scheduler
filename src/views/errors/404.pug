doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title 404 Not Found
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css", rel="stylesheet")
    style.
      body { background-color: #f3f4f6; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
      .error-card { text-align: center; max-width: 500px; padding: 3rem; background: white; border-radius: 1rem; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
      h1 { font-size: 6rem; color: #4f46e5; margin: 0; }
  body
    .error-card
      h1 404
      h3 Page Not Found
      p.text-muted.mb-4 The page you are looking for doesn't exist or has been moved.
      a.btn.btn-primary(href="/") Return Home
