doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title 500 Internal Server Error
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css", rel="stylesheet")
    style.
      body { background-color: #f3f4f6; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
      .error-card { text-align: center; max-width: 600px; padding: 3rem; background: white; border-radius: 1rem; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
      h1 { font-size: 6rem; color: #ef4444; margin: 0; }
      .error-msg { background: #fef2f2; color: #991b1b; padding: 1rem; border-radius: 0.5rem; text-align: left; margin-bottom: 2rem; overflow-x: auto; }
  body
    .error-card
      h1 500
      h3 Internal Server Error
      p.text-muted.mb-4 Something went wrong on our end. Please try again later.
      if message
        .error-msg= message
      a.btn.btn-primary(href="/") Return Home
