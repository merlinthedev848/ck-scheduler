doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title #{title}
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css")
    style.
      :root {
        --primary: #{settings.primary_color || '#4f46e5'};
        --primary-hover: #{settings.primary_color ? settings.primary_color + 'cc' : '#4338ca'};
        --bg-dark: #0f172a;
        --bg-card: rgba(255, 255, 255, 0.95);
        --text-main: #1e293b;
        --text-muted: #64748b;
        --border: #e2e8f0;
      }
      
      * { box-sizing: border-box; margin: 0; padding: 0; }
      
      body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, var(--bg-dark) 0%, #1e1b4b 100%);
        color: var(--text-main);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 1rem;
        -webkit-font-smoothing: antialiased;
      }

      .header {
        text-align: center;
        color: white;
        margin-bottom: 2rem;
        animation: fadeInDown 0.8s ease-out;
      }
      .header h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem; text-shadow: 0 2px 4px rgba(0,0,0,0.3); }
      .header p { font-size: 1.1rem; color: rgba(255,255,255,0.8); }

      .wizard-container {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.1) inset;
        width: 100%;
        max-width: 800px;
        overflow: hidden;
        animation: slideUp 0.6s ease-out;
        display: flex;
        flex-direction: column;
      }

      .stepper {
        display: flex;
        padding: 1.5rem 2rem;
        background: rgba(255,255,255,0.5);
        border-bottom: 1px solid var(--border);
      }
      .step {
        flex: 1;
        text-align: center;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-muted);
        position: relative;
        transition: color 0.3s;
      }
      .step.active { color: var(--primary); }
      .step.completed { color: var(--primary); }
      .step-icon {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: white;
        border: 2px solid var(--border);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 0.5rem;
        transition: all 0.3s;
      }
      .step.active .step-icon { border-color: var(--primary); background: var(--primary); color: white; box-shadow: 0 0 15px rgba(79, 70, 229, 0.4); }
      .step.completed .step-icon { border-color: var(--primary); background: var(--primary); color: white; }
      
      .step:not(:last-child)::after {
        content: ''; position: absolute;
        top: 16px; left: 50%; width: 100%; height: 2px;
        background: var(--border); z-index: -1;
      }
      .step.completed:not(:last-child)::after { background: var(--primary); }

      .step-content {
        padding: 2.5rem;
        display: none;
        animation: fadeIn 0.4s ease;
      }
      .step-content.active { display: block; }

      h2.step-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--text-main); }

      /* Grid Selections */
      .grid-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem;
      }
      .card-select {
        background: white;
        border: 2px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-align: left;
      }
      .card-select:hover {
        border-color: var(--primary);
        transform: translateY(-4px);
        box-shadow: 0 10px 20px -5px rgba(79, 70, 229, 0.15);
      }
      .card-select.selected {
        border-color: var(--primary);
        background: rgba(79, 70, 229, 0.05);
        box-shadow: 0 0 0 1px var(--primary) inset;
      }
      .card-title { font-weight: 600; font-size: 1.1rem; margin-bottom: 0.5rem; }
      .card-meta { font-size: 0.875rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.5rem; }

      /* Calendar/Time */
      .datetime-container { display: flex; gap: 2rem; flex-wrap: wrap; }
      .calendar-wrapper { flex: 1; min-width: 300px; }
      .time-wrapper { flex: 1; min-width: 250px; }
      
      .month-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
      .btn-icon { background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-main); transition: color 0.2s; }
      .btn-icon:hover { color: var(--primary); }
      
      .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.5rem; text-align: center; }
      .cal-day-header { font-size: 0.75rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; padding-bottom: 0.5rem; }
      .cal-day {
        aspect-ratio: 1;
        display: flex; align-items: center; justify-content: center;
        border-radius: 50%;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid transparent;
      }
      .cal-day.disabled { color: #cbd5e1; cursor: not-allowed; }
      .cal-day.available { background: #f8fafc; border-color: var(--border); }
      .cal-day.available:hover { border-color: var(--primary); color: var(--primary); }
      .cal-day.selected { background: var(--primary); color: white; border-color: var(--primary); box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3); transform: scale(1.1); }

      .time-slots { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; max-height: 300px; overflow-y: auto; padding-right: 0.5rem; }
      .time-slots::-webkit-scrollbar { width: 6px; }
      .time-slots::-webkit-scrollbar-track { background: transparent; }
      .time-slots::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
      .slot {
        padding: 0.75rem 0;
        text-align: center;
        background: white;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
      }
      .slot:hover { border-color: var(--primary); color: var(--primary); }
      .slot.selected { background: var(--primary); color: white; border-color: var(--primary); }

      /* Form */
      .form-group { margin-bottom: 1.5rem; }
      .form-label { display: block; font-weight: 500; margin-bottom: 0.5rem; font-size: 0.9rem; }
      .form-control {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid var(--border);
        border-radius: 12px;
        font-family: inherit;
        font-size: 1rem;
        transition: all 0.3s;
        background: #f8fafc;
      }
      .form-control:focus { outline: none; border-color: var(--primary); background: white; box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }
      
      .summary-box {
        background: #f8fafc;
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        border: 1px solid var(--border);
      }
      .summary-item { display: flex; justify-content: space-between; margin-bottom: 0.75rem; padding-bottom: 0.75rem; border-bottom: 1px dashed var(--border); }
      .summary-item:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
      .summary-label { color: var(--text-muted); font-size: 0.9rem; }
      .summary-value { font-weight: 600; text-align: right; }

      /* Footer / Actions */
      .wizard-footer {
        padding: 1.5rem 2.5rem;
        background: #f8fafc;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        font-family: inherit;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s;
        border: none;
        display: inline-flex; align-items: center; gap: 0.5rem;
      }
      .btn-outline { background: white; border: 1px solid var(--border); color: var(--text-main); }
      .btn-outline:hover { background: #f1f5f9; }
      .btn-primary { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2); }
      .btn-primary:hover { background: var(--primary-hover); transform: translateY(-2px); box-shadow: 0 6px 16px rgba(79, 70, 229, 0.3); }
      .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; transform: none; box-shadow: none; }

      /* Animations */
      @keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes slideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      
      .loader {
        display: inline-block; width: 20px; height: 20px;
        border: 3px solid rgba(255,255,255,0.3); border-radius: 50%;
        border-top-color: white; animation: spin 1s ease-in-out infinite;
        display: none;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

  body
    .header
      h1= settings.company_name || 'CK Scheduler'
      p Schedule your appointment online

    .wizard-container
      .stepper
        .step.active#nav-step-1
          .step-icon 1
          | Service
        .step#nav-step-2
          .step-icon 2
          | Provider
        .step#nav-step-3
          .step-icon 3
          | Date & Time
        .step#nav-step-4
          .step-icon 4
          | Details

      // STEP 1: Service
      .step-content.active#step-1
        h2.step-title Choose a Service
        .grid-list
          each s in services
            .card-select(data-service-id=s.id data-service-name=s.name data-duration=s.duration data-price=s.price onclick="selectService(this)")
              .card-title= s.name
              .card-meta
                i.bi.bi-clock
                span #{s.duration} min
                if settings.hide_prices !== '1'
                  span.ms-auto.fw-bold(style="color:var(--primary)")= s.price > 0 ? (s.currency + s.price) : 'Free'
              if s.description
                p.mt-2.mb-0.text-muted(style="font-size:0.85rem")= s.description

      // STEP 2: Provider
      .step-content#step-2
        h2.step-title Choose a Provider
        #provider-list.grid-list
          // Injected via JS

      // STEP 3: Date & Time
      .step-content#step-3
        h2.step-title Select Date & Time
        .datetime-container
          .calendar-wrapper
            .month-header
              button.btn-icon(onclick="changeMonth(-1)") <i class="bi bi-chevron-left"></i>
              strong#month-display(style="font-size:1.1rem")
              button.btn-icon(onclick="changeMonth(1)") <i class="bi bi-chevron-right"></i>
            .calendar-grid
              .cal-day-header Su
              .cal-day-header Mo
              .cal-day-header Tu
              .cal-day-header We
              .cal-day-header Th
              .cal-day-header Fr
              .cal-day-header Sa
            .calendar-grid#calendar-days
          
          .time-wrapper
            .d-flex.justify-content-between.align-items-center.mb-3
              strong Available Times
              small#selected-date-text.text-muted Select a date
            #time-slots.time-slots
              p.text-muted.w-100(style="grid-column: 1 / -1; text-align: center; margin-top: 2rem;") Please select a date first.

      // STEP 4: Details
      .step-content#step-4
        h2.step-title Your Details
        .row
          .col-md-6
            .summary-box
              h6.mb-3 Booking Summary
              .summary-item
                span.summary-label Service
                span.summary-value#sum-service
              .summary-item
                span.summary-label Provider
                span.summary-value#sum-provider
              .summary-item
                span.summary-label Date
                span.summary-value#sum-date
              .summary-item
                span.summary-label Time
                span.summary-value#sum-time
              if settings.hide_prices !== '1'
                .summary-item
                  span.summary-label Total
                  span.summary-value(style="color:var(--primary);font-size:1.1rem;")#sum-price
              
          .col-md-6
            form#booking-form
              .row
                .col-sm-6.form-group
                  label.form-label First Name
                  input.form-control(type="text" id="bf-fname" required)
                .col-sm-6.form-group
                  label.form-label Last Name
                  input.form-control(type="text" id="bf-lname" required)
              .form-group
                label.form-label Email Address
                input.form-control(type="email" id="bf-email" required)
              .form-group
                label.form-label Phone Number
                input.form-control(type="tel" id="bf-phone" required=(settings.require_phone==='1'))
              .form-group
                label.form-label Additional Notes (Optional)
                textarea.form-control(id="bf-notes" rows="2")

      .wizard-footer
        button.btn.btn-outline#btn-back(onclick="prevStep()" style="visibility:hidden") <i class="bi bi-arrow-left"></i> Back
        button.btn.btn-primary#btn-next(onclick="nextStep()" disabled) Next Step <i class="bi bi-arrow-right"></i>
        button.btn.btn-primary#btn-submit(onclick="submitBooking()" style="display:none") 
          span.loader#submit-loader
          span#submit-text Confirm Booking

    script.
      const state = {
        step: 1,
        serviceId: null, serviceName: null, price: null,
        providerId: null, providerName: null,
        date: null, time: null,
        currentMonth: new Date().getMonth(),
        currentYear: new Date().getFullYear(),
        availableDates: []
      };

      // Navigation
      function updateNav() {
        document.querySelectorAll('.step-content').forEach(el => el.classList.remove('active'));
        document.getElementById(`step-${state.step}`).classList.add('active');
        
        document.querySelectorAll('.step').forEach((el, idx) => {
          el.classList.remove('active', 'completed');
          if (idx + 1 === state.step) el.classList.add('active');
          if (idx + 1 < state.step) el.classList.add('completed');
        });

        document.getElementById('btn-back').style.visibility = state.step > 1 ? 'visible' : 'hidden';
        
        const nextBtn = document.getElementById('btn-next');
        const submitBtn = document.getElementById('btn-submit');
        
        if (state.step === 4) {
          nextBtn.style.display = 'none';
          submitBtn.style.display = 'inline-flex';
          updateSummary();
        } else {
          nextBtn.style.display = 'inline-flex';
          submitBtn.style.display = 'none';
        }

        validateStep();
      }

      function nextStep() {
        if (state.step < 4) {
          state.step++;
          if(state.step === 2) fetchProviders();
          if(state.step === 3) { state.date = null; state.time = null; fetchAvailableDates(); renderCalendar(); document.getElementById('time-slots').innerHTML = '<p class="text-muted w-100" style="grid-column: 1 / -1; text-align: center; margin-top: 2rem;">Please select a date first.</p>'; document.getElementById('selected-date-text').innerText = 'Select a date';}
          updateNav();
        }
      }

      function prevStep() {
        if (state.step > 1) { state.step--; updateNav(); }
      }

      function validateStep() {
        const nextBtn = document.getElementById('btn-next');
        if (state.step === 1) nextBtn.disabled = !state.serviceId;
        else if (state.step === 2) nextBtn.disabled = !state.providerId;
        else if (state.step === 3) nextBtn.disabled = !(state.date && state.time);
      }

      // Step 1: Service
      function selectService(el) {
        document.querySelectorAll('#step-1 .card-select').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        state.serviceId = el.dataset.serviceId;
        state.serviceName = el.dataset.serviceName;
        state.price = el.dataset.price;
        validateStep();
      }

      // Step 2: Provider
      async function fetchProviders() {
        const res = await fetch(`/booking/providers/${state.serviceId}`);
        const providers = await res.json();
        const list = document.getElementById('provider-list');
        list.innerHTML = '';
        providers.forEach(p => {
          const card = document.createElement('div');
          card.className = 'card-select';
          card.onclick = () => {
            document.querySelectorAll('#step-2 .card-select').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            state.providerId = p.id;
            state.providerName = `${p.first_name} ${p.last_name}`;
            validateStep();
          };
          card.innerHTML = `<div class="card-title">${p.first_name} ${p.last_name}</div><div class="card-meta"><i class="bi bi-person-badge"></i> Provider</div>`;
          list.appendChild(card);
        });
        
        // Auto select if only 1
        if(providers.length === 1) {
          list.firstChild.click();
          setTimeout(nextStep, 300);
        }
      }

      // Step 3: Calendar
      const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
      
      async function fetchAvailableDates() {
        const res = await fetch(`/booking/available-dates/${state.providerId}/${state.serviceId}/${state.currentYear}/${state.currentMonth + 1}`);
        const data = await res.json();
        state.availableDates = data.dates;
        renderCalendar();
      }

      function changeMonth(dir) {
        state.currentMonth += dir;
        if (state.currentMonth < 0) { state.currentMonth = 11; state.currentYear--; }
        else if (state.currentMonth > 11) { state.currentMonth = 0; state.currentYear++; }
        fetchAvailableDates();
      }

      function renderCalendar() {
        document.getElementById('month-display').innerText = `${monthNames[state.currentMonth]} ${state.currentYear}`;
        const grid = document.getElementById('calendar-days');
        grid.innerHTML = '';
        
        const firstDay = new Date(state.currentYear, state.currentMonth, 1).getDay();
        const daysInMonth = new Date(state.currentYear, state.currentMonth + 1, 0).getDate();
        
        for (let i = 0; i < firstDay; i++) {
          const empty = document.createElement('div');
          grid.appendChild(empty);
        }
        
        const todayStr = new Date().toISOString().split('T')[0];

        for (let d = 1; d <= daysInMonth; d++) {
          const dateStr = `${state.currentYear}-${String(state.currentMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
          const cell = document.createElement('div');
          cell.className = 'cal-day';
          cell.innerText = d;
          
          if (dateStr < todayStr) {
            cell.classList.add('disabled');
          } else if (state.availableDates.includes(dateStr)) {
            cell.classList.add('available');
            if (state.date === dateStr) cell.classList.add('selected');
            cell.onclick = () => selectDate(dateStr, cell);
          } else {
            cell.classList.add('disabled');
          }
          
          grid.appendChild(cell);
        }
      }

      async function selectDate(dateStr, cell) {
        document.querySelectorAll('.cal-day').forEach(c => c.classList.remove('selected'));
        cell.classList.add('selected');
        state.date = dateStr;
        state.time = null;
        validateStep();
        
        const dObj = new Date(dateStr);
        document.getElementById('selected-date-text').innerText = dObj.toLocaleDateString(undefined, {weekday:'short', month:'short', day:'numeric'});
        
        const slotsDiv = document.getElementById('time-slots');
        slotsDiv.innerHTML = '<div style="grid-column:1/-1;text-align:center"><i class="bi bi-arrow-repeat spin"></i> Loading...</div>';
        
        const res = await fetch(`/booking/slots/${state.providerId}/${dateStr}?serviceId=${state.serviceId}`);
        const data = await res.json();
        
        slotsDiv.innerHTML = '';
        if (data.slots.length === 0) {
          slotsDiv.innerHTML = '<p class="text-muted w-100" style="grid-column: 1 / -1; text-align: center;">No slots available.</p>';
          return;
        }
        
        data.slots.forEach(t => {
          const slot = document.createElement('div');
          slot.className = 'slot';
          slot.innerText = t;
          slot.onclick = () => {
            document.querySelectorAll('.slot').forEach(s => s.classList.remove('selected'));
            slot.classList.add('selected');
            state.time = t;
            validateStep();
          };
          slotsDiv.appendChild(slot);
        });
      }

      // Step 4: Summary & Submit
      function updateSummary() {
        document.getElementById('sum-service').innerText = state.serviceName;
        document.getElementById('sum-provider').innerText = state.providerName;
        document.getElementById('sum-date').innerText = new Date(state.date).toLocaleDateString(undefined, {weekday:'long', month:'long', day:'numeric'});
        document.getElementById('sum-time').innerText = state.time;
        if(document.getElementById('sum-price')) {
           document.getElementById('sum-price').innerText = parseFloat(state.price) > 0 ? ('£' + state.price) : 'Free';
        }
      }

      async function submitBooking() {
        const form = document.getElementById('booking-form');
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        const btn = document.getElementById('btn-submit');
        const loader = document.getElementById('submit-loader');
        const txt = document.getElementById('submit-text');
        
        btn.disabled = true;
        loader.style.display = 'inline-block';
        txt.innerText = ' Processing...';

        const payload = {
          service_id: state.serviceId,
          provider_id: state.providerId,
          date: state.date,
          time: state.time,
          first_name: document.getElementById('bf-fname').value,
          last_name: document.getElementById('bf-lname').value,
          email: document.getElementById('bf-email').value,
          phone: document.getElementById('bf-phone').value,
          notes: document.getElementById('bf-notes').value
        };

        try {
          const res = await fetch('/booking/book', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await res.json();
          
          if (res.ok && data.redirect) {
            window.location.href = data.redirect;
          } else {
            alert(data.error || 'An error occurred.');
            btn.disabled = false;
            loader.style.display = 'none';
            txt.innerText = ' Confirm Booking';
          }
        } catch (e) {
          alert('Network error. Please try again.');
          btn.disabled = false;
          loader.style.display = 'none';
          txt.innerText = ' Confirm Booking';
        }
      }
