extends ../layout

block content
  .card.shadow-sm
    .card-header.bg-white.d-flex.justify-content-between.align-items-center
      h5.m-0 Customers
      .d-flex.gap-2
        form.d-flex.gap-2(method="GET" action="/customers")
          input.form-control.form-control-sm(type="search" name="search" placeholder="Search..." value=search)
          button.btn.btn-outline-secondary.btn-sm(type="submit") Search
        button.btn.btn-primary.btn-sm(data-bs-toggle="modal" data-bs-target="#addCustomerModal") Add Customer
    .card-body.p-0
      .table-responsive
        table.table.table-hover.m-0
          thead.table-light
            tr
              th Name
              th Email
              th Phone
              th Registered
              th Actions
          tbody
            each c in customers
              tr
                td= `${c.first_name} ${c.last_name}`
                td= c.email
                td= c.phone || '—'
                td= new Date(c.created_at).toLocaleDateString()
                td
                  a.btn.btn-sm.btn-outline-primary.me-2(href=`/customers/${c.id}`) View
                  form.d-inline(action=`/customers/${c.id}?_method=DELETE` method="POST" onsubmit="return confirm('Delete this customer?');")
                    button.btn.btn-sm.btn-outline-danger(type="submit") Delete
            if customers.length === 0
              tr
                td.text-center.py-4(colspan="5") No customers found.
    .card-footer.bg-white
      nav
        ul.pagination.pagination-sm.m-0.justify-content-end
          li.page-item(class=(page <= 1 ? 'disabled' : ''))
            a.page-link(href=`?page=${page-1}&search=${search||''}`) Previous
          li.page-item(class=(page >= totalPages ? 'disabled' : ''))
            a.page-link(href=`?page=${page+1}&search=${search||''}`) Next

  // Add Customer Modal
  #addCustomerModal.modal.fade(tabindex="-1")
    .modal-dialog
      .modal-content
        form(action="/customers" method="POST")
          .modal-header
            h5.modal-title Add Customer
            button.btn-close(type="button" data-bs-dismiss="modal")
          .modal-body
            .row.g-3
              .col-md-6
                label.form-label First Name
                input.form-control(type="text" name="first_name" required)
              .col-md-6
                label.form-label Last Name
                input.form-control(type="text" name="last_name" required)
              .col-12
                label.form-label Email
                input.form-control(type="email" name="email" required)
              .col-12
                label.form-label Phone
                input.form-control(type="tel" name="phone")
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
            button.btn.btn-primary(type="submit") Add Customer
