extends ../layout

block content
  .row
    .col-md-4
      .card.shadow-sm.mb-4
        .card-header.bg-white
          h5.m-0 Customer Profile
        .card-body
          form(action=`/customers/${customer.id}?_method=PUT` method="POST")
            .mb-3
              label.form-label First Name
              input.form-control(type="text" name="first_name" value=customer.first_name required)
            .mb-3
              label.form-label Last Name
              input.form-control(type="text" name="last_name" value=customer.last_name required)
            .mb-3
              label.form-label Email
              input.form-control(type="email" name="email" value=customer.email required)
            .mb-3
              label.form-label Phone
              input.form-control(type="tel" name="phone" value=customer.phone)
            .mb-3
              label.form-label Address
              input.form-control(type="text" name="address" value=customer.address)
            .mb-3
              label.form-label Notes
              textarea.form-control(name="notes" rows="4")= customer.notes
            .text-end
              button.btn.btn-primary(type="submit") Update Profile
    
    .col-md-8
      .card.shadow-sm
        .card-header.bg-white
          h5.m-0 Appointment History
        .card-body.p-0
          .table-responsive
            table.table.table-hover.m-0
              thead.table-light
                tr
                  th Date
                  th Service
                  th Provider
                  th Status
              tbody
                each a in appointments
                  tr
                    td
                      a.text-decoration-none(href=`/appointments/${a.id}`)
                        div= new Date(a.start_datetime).toLocaleDateString()
                        small.text-muted= new Date(a.start_datetime).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})
                    td= a.service_name
                    td= `${a.provider_first_name} ${a.provider_last_name}`
                    td
                      span.badge(class=`bg-${a.status === 'confirmed' ? 'success' : (a.status === 'pending' ? 'warning' : 'danger')}`)
                        | #{a.status}
                if appointments.length === 0
                  tr
                    td.text-center.py-4(colspan="4") No appointments found.
