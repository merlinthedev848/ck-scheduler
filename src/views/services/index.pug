extends ../layout

block content
  .card.shadow-sm
    .card-header.bg-white.d-flex.justify-content-between.align-items-center
      h5.m-0 Services
      button.btn.btn-primary.btn-sm(data-bs-toggle="modal" data-bs-target="#addServiceModal") Add Service
    .card-body.p-0
      .table-responsive
        table.table.table-hover.m-0
          thead.table-light
            tr
              th Name
              th Category
              th Duration (min)
              th Price
              th Requires Payment
              th Actions
          tbody
            each s in services
              tr
                td= s.name
                td= s.category_name || '—'
                td= s.duration
                td= s.currency + ' ' + s.price
                td= s.requires_payment ? 'Yes' : 'No'
                td
                  button.btn.btn-sm.btn-outline-primary.me-2(data-bs-toggle="modal" data-bs-target=`#editServiceModal${s.id}`) Edit
                  form.d-inline(action=`/services/${s.id}?_method=DELETE` method="POST" onsubmit="return confirm('Delete this service?');")
                    button.btn.btn-sm.btn-outline-danger(type="submit") Delete

              // Edit Modal
              .modal.fade(id=`editServiceModal${s.id}` tabindex="-1")
                .modal-dialog
                  .modal-content
                    form(action=`/services/${s.id}?_method=PUT` method="POST")
                      .modal-header
                        h5.modal-title Edit Service
                        button.btn-close(type="button" data-bs-dismiss="modal")
                      .modal-body
                        .mb-3
                          label.form-label Name
                          input.form-control(type="text" name="name" value=s.name required)
                        .mb-3
                          label.form-label Category
                          select.form-select(name="category_id")
                            option(value="") None
                            each c in categories
                              option(value=c.id selected=(c.id===s.category_id))= c.name
                        .mb-3
                          label.form-label Description
                          textarea.form-control(name="description")= s.description
                        .row
                          .col-md-6.mb-3
                            label.form-label Duration (min)
                            input.form-control(type="number" name="duration" value=s.duration required)
                          .col-md-6.mb-3
                            label.form-label Price
                            input.form-control(type="number" step="0.01" name="price" value=s.price required)
                        .mb-3
                          .form-check.form-switch
                            input.form-check-input(type="checkbox" name="requires_payment" value="1" checked=(s.requires_payment===1))
                            label.form-check-label Require payment during booking
                        .mb-3
                          label.form-label Custom Intake Questions (Comma separated)
                          - const qVal = s.custom_questions ? (typeof s.custom_questions === 'string' ? JSON.parse(s.custom_questions).join(', ') : s.custom_questions.join(', ')) : ''
                          input.form-control(type="text" name="custom_questions" value=qVal placeholder="e.g. Age, Any allergies?")
                      .modal-footer
                        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
                        button.btn.btn-primary(type="submit") Save Changes

  // Add Service Modal
  #addServiceModal.modal.fade(tabindex="-1")
    .modal-dialog
      .modal-content
        form(action="/services" method="POST")
          .modal-header
            h5.modal-title Add Service
            button.btn-close(type="button" data-bs-dismiss="modal")
          .modal-body
            .mb-3
              label.form-label Name
              input.form-control(type="text" name="name" required)
            .mb-3
              label.form-label Category
              select.form-select(name="category_id")
                option(value="") None
                each c in categories
                  option(value=c.id)= c.name
            .mb-3
              label.form-label Description
              textarea.form-control(name="description")
            .row
              .col-md-6.mb-3
                label.form-label Duration (min)
                input.form-control(type="number" name="duration" value="60" required)
              .col-md-6.mb-3
                label.form-label Price
                input.form-control(type="number" step="0.01" name="price" value="0.00" required)
            .mb-3
              .form-check.form-switch
                input.form-check-input(type="checkbox" name="requires_payment" value="1")
                label.form-check-label Require payment during booking
            .mb-3
              label.form-label Custom Intake Questions (Comma separated)
              input.form-control(type="text" name="custom_questions" placeholder="e.g. Age, Any allergies?")
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
            button.btn.btn-primary(type="submit") Add Service
