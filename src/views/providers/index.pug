extends ../layout

block content
  .card.shadow-sm
    .card-header.bg-white.d-flex.justify-content-between.align-items-center
      h5.m-0 Providers
      button.btn.btn-primary.btn-sm(data-bs-toggle="modal" data-bs-target="#addProviderModal") Add Provider
    .card-body.p-0
      .table-responsive
        table.table.table-hover.m-0
          thead.table-light
            tr
              th Name
              th Email
              th Phone
              th Services
              th Actions
          tbody
            each p in providers
              tr
                td
                  if !p.is_active
                    span.badge.bg-secondary.me-2 Inactive
                  | #{p.first_name} #{p.last_name}
                td= p.email
                td= p.phone || '—'
                td
                  if p.services && p.services.length
                    each s in p.services
                      span.badge.bg-light.text-dark.border.me-1= s.name
                  else
                    span.text-muted None
                td
                  button.btn.btn-sm.btn-outline-primary.me-2(data-bs-toggle="modal" data-bs-target=`#editProviderModal${p.id}`) Edit
                  button.btn.btn-sm.btn-outline-info.me-2(onclick=`editWorkingPlan(${p.id})`) Working Plan
                  form.d-inline(action=`/providers/${p.id}?_method=DELETE` method="POST" onsubmit="return confirm('Delete this provider?');")
                    button.btn.btn-sm.btn-outline-danger(type="submit") Delete

              // Edit Provider Modal
              .modal.fade(id=`editProviderModal${p.id}` tabindex="-1")
                .modal-dialog.modal-lg
                  .modal-content
                    form(action=`/providers/${p.id}?_method=PUT` method="POST")
                      .modal-header
                        h5.modal-title Edit Provider
                        button.btn-close(type="button" data-bs-dismiss="modal")
                      .modal-body
                        .row.g-3
                          .col-md-6
                            label.form-label First Name
                            input.form-control(type="text" name="first_name" value=p.first_name required)
                          .col-md-6
                            label.form-label Last Name
                            input.form-control(type="text" name="last_name" value=p.last_name required)
                          .col-md-6
                            label.form-label Email
                            input.form-control(type="email" name="email" value=p.email required)
                          .col-md-6
                            label.form-label Phone
                            input.form-control(type="tel" name="phone" value=p.phone)
                          .col-md-6
                            label.form-label Reset Password (leave blank to keep current)
                            input.form-control(type="password" name="password")
                          .col-md-6
                            .form-check.mt-4
                              input.form-check-input(type="checkbox" name="is_active" value="1" checked=(p.is_active===1))
                              label.form-check-label Account Active
                          .col-12
                            label.form-label Services Provided
                            select.form-select(name="services" multiple size="4")
                              - const providerServiceIds = p.services.map(s => s.id)
                              each s in allServices
                                option(value=s.id selected=(providerServiceIds.includes(s.id)))= s.name
                      .modal-footer
                        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
                        button.btn.btn-primary(type="submit") Save Changes

  // Add Provider Modal
  #addProviderModal.modal.fade(tabindex="-1")
    .modal-dialog.modal-lg
      .modal-content
        form(action="/providers" method="POST")
          .modal-header
            h5.modal-title Add Provider
            button.btn-close(type="button" data-bs-dismiss="modal")
          .modal-body
            .row.g-3
              .col-md-6
                label.form-label First Name
                input.form-control(type="text" name="first_name" required)
              .col-md-6
                label.form-label Last Name
                input.form-control(type="text" name="last_name" required)
              .col-md-6
                label.form-label Email
                input.form-control(type="email" name="email" required)
              .col-md-6
                label.form-label Phone
                input.form-control(type="tel" name="phone")
              .col-md-6
                label.form-label Password
                input.form-control(type="password" name="password" required)
              .col-md-6
                .form-check.mt-4
                  input.form-check-input(type="checkbox" name="is_active" value="1" checked)
                  label.form-check-label Account Active
              .col-12
                label.form-label Services Provided
                select.form-select(name="services" multiple size="4")
                  each s in allServices
                    option(value=s.id)= s.name
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
            button.btn.btn-primary(type="submit") Add Provider

  // Working Plan Modal (Handled via JS)
  #workingPlanModal.modal.fade(tabindex="-1")
    .modal-dialog.modal-lg
      .modal-content
        .modal-header
          h5.modal-title Edit Working Plan
          button.btn-close(type="button" data-bs-dismiss="modal")
        .modal-body#workingPlanBody
          // Populated via JS
        .modal-footer
          button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
          button.btn.btn-primary(type="button" onclick="saveWorkingPlan()") Save Working Plan

block scripts
  script.
    let currentProviderId = null;
    
    function editWorkingPlan(id) {
      currentProviderId = id;
      fetch(`/providers/${id}/working-plan`)
        .then(res => res.json())
        .then(data => {
          renderWorkingPlanForm(data.plan);
          new bootstrap.Modal(document.getElementById('workingPlanModal')).show();
        });
    }

    function renderWorkingPlanForm(plan) {
      const days = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];
      let html = '<div class="row g-3">';
      days.forEach(day => {
        const d = plan[day];
        const isWorking = d !== null;
        html += `
          <div class="col-12 border-bottom pb-2">
            <div class="d-flex align-items-center mb-2">
              <div class="form-check form-switch me-3">
                <input class="form-check-input wp-day-toggle" type="checkbox" data-day="${day}" ${isWorking ? 'checked' : ''}>
                <label class="form-check-label text-capitalize fw-bold">${day}</label>
              </div>
            </div>
            <div class="row g-2 wp-time-inputs" id="wp-times-${day}" style="display: ${isWorking ? 'flex' : 'none'}">
              <div class="col-md-3">
                <label class="form-label small">Start</label>
                <input type="time" class="form-control form-control-sm wp-start" data-day="${day}" value="${d ? d.start : '09:00'}">
              </div>
              <div class="col-md-3">
                <label class="form-label small">End</label>
                <input type="time" class="form-control form-control-sm wp-end" data-day="${day}" value="${d ? d.end : '17:00'}">
              </div>
            </div>
          </div>
        `;
      });
      html += '</div>';
      document.getElementById('workingPlanBody').innerHTML = html;

      document.querySelectorAll('.wp-day-toggle').forEach(el => {
        el.addEventListener('change', (e) => {
          document.getElementById(`wp-times-${e.target.dataset.day}`).style.display = e.target.checked ? 'flex' : 'none';
        });
      });
    }

    function saveWorkingPlan() {
      const days = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];
      const plan = {};
      
      days.forEach(day => {
        const toggle = document.querySelector(`.wp-day-toggle[data-day="${day}"]`);
        if (toggle.checked) {
          plan[day] = {
            start: document.querySelector(`.wp-start[data-day="${day}"]`).value,
            end: document.querySelector(`.wp-end[data-day="${day}"]`).value,
            breaks: []
          };
        } else {
          plan[day] = null;
        }
      });

      fetch(`/providers/${currentProviderId}/working-plan`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plan })
      }).then(() => location.reload());
    }
