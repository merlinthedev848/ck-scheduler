doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title #{title}
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css")
    style.
      :root {
        --primary: #4f46e5;
        --bg-dark: #0f172a;
        --bg-card: rgba(255, 255, 255, 0.95);
        --text-main: #1e293b;
        --border: #e2e8f0;
      }
      body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, var(--bg-dark) 0%, #1e1b4b 100%);
        color: var(--text-main);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 1rem;
      }
      .wizard-container {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        width: 100%;
        max-width: 700px;
        overflow: hidden;
        animation: slideUp 0.6s ease-out;
      }
      .stepper { display: flex; padding: 1.5rem 2rem; background: rgba(255,255,255,0.5); border-bottom: 1px solid var(--border); }
      .step { flex: 1; text-align: center; font-size: 0.875rem; font-weight: 600; color: #64748b; }
      .step.active { color: var(--primary); }
      .step-icon { width: 32px; height: 32px; border-radius: 50%; background: white; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; margin: 0 auto 0.5rem; }
      .step.active .step-icon { border-color: var(--primary); background: var(--primary); color: white; }
      .step-content { padding: 2.5rem; display: none; }
      .step-content.active { display: block; animation: fadeIn 0.4s ease; }
      h2.step-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; }
      .form-label { font-weight: 500; margin-bottom: 0.5rem; display: block; }
      .form-control { width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--border); border-radius: 12px; font-family: inherit; font-size: 1rem; margin-bottom: 1.5rem; background: #f8fafc; }
      .form-control:focus { outline: none; border-color: var(--primary); background: white; box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }
      .wizard-footer { padding: 1.5rem 2.5rem; background: #f8fafc; border-top: 1px solid var(--border); display: flex; justify-content: space-between; }
      .btn { padding: 0.75rem 1.5rem; border-radius: 12px; font-weight: 600; cursor: pointer; border: none; font-size: 1rem; }
      .btn-primary { background: var(--primary); color: white; }
      .btn-outline { background: white; border: 1px solid var(--border); }
      @keyframes slideUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
      @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
      .loader { display: none; width: 20px; height: 20px; border: 3px solid rgba(255,255,255,0.3); border-radius: 50%; border-top-color: white; animation: spin 1s infinite; vertical-align: middle; margin-right: 8px; }
      @keyframes spin { to { transform: rotate(360deg); } }
      .error-box { background: #fee2e2; color: #991b1b; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; display: none; }
      .success-box { background: #dcfce7; color: #166534; padding: 2rem; border-radius: 12px; text-align: center; display: none; }

  body
    .text-center.text-white.mb-4
      h1(style="font-weight:700") Setup CK Scheduler

    .wizard-container
      .stepper
        .step.active#nav-step-1
          .step-icon 1
          | Database
        .step#nav-step-2
          .step-icon 2
          | Admin Account
        .step#nav-step-3
          .step-icon 3
          | Business

      form#setup-form(onsubmit="return false;")
        .error-box#error-msg
        
        // STEP 1
        .step-content.active#step-1
          h2.step-title MySQL Database Configuration
          p.text-muted We need a MySQL database to store your data.
          .form-group
            label.form-label Database Host
            input.form-control(type="text" id="db_host" value="127.0.0.1" required)
          .form-group
            label.form-label Database Port
            input.form-control(type="number" id="db_port" value="3306" required)
          .form-group
            label.form-label Database Name
            input.form-control(type="text" id="db_name" value="ck_scheduler" required)
          .form-group
            label.form-label Database User
            input.form-control(type="text" id="db_user" value="root" required)
          .form-group
            label.form-label Database Password
            input.form-control(type="password" id="db_pass")

        // STEP 2
        .step-content#step-2
          h2.step-title Create Admin Account
          p.text-muted This account will be used to access the dashboard.
          div(style="display:flex; gap:1rem")
            .form-group(style="flex:1")
              label.form-label First Name
              input.form-control(type="text" id="admin_fname" required)
            .form-group(style="flex:1")
              label.form-label Last Name
              input.form-control(type="text" id="admin_lname" required)
          .form-group
            label.form-label Email Address
            input.form-control(type="email" id="admin_email" required)
          .form-group
            label.form-label Password
            input.form-control(type="password" id="admin_pass" minlength="8" required)

        // STEP 3
        .step-content#step-3
          h2.step-title Business Information
          p.text-muted How your business will appear to customers.
          .form-group
            label.form-label Business Name
            input.form-control(type="text" id="business_name" value="CK Scheduler" required)

        // SUCCESS
        .step-content#step-success
          .success-box#success-box(style="display:block")
            i.bi.bi-check-circle-fill(style="font-size:3rem; margin-bottom:1rem; display:block")
            h2 Setup Complete!
            p The database has been configured and the admin account is ready.
            strong IMPORTANT: Please restart your server manually (Ctrl+C then <code>npm start</code>) for the changes to take effect!
            p.mt-4
              a.btn.btn-primary(href="/calendar") Go to Dashboard

        .wizard-footer#wizard-footer
          button.btn.btn-outline#btn-back(type="button" onclick="prevStep()" style="visibility:hidden") Back
          button.btn.btn-primary#btn-next(type="button" onclick="nextStep()") Next Step
          button.btn.btn-primary#btn-submit(type="button" onclick="submitSetup()" style="display:none") 
            span.loader#submit-loader
            span#submit-text Finish Setup

    script.
      let step = 1;
      
      function updateNav() {
        document.querySelectorAll('.step-content').forEach(e => e.classList.remove('active'));
        document.getElementById(`step-${step}`).classList.add('active');
        document.querySelectorAll('.step').forEach((e, i) => {
          e.classList.remove('active');
          if (i + 1 <= step) e.classList.add('active');
        });
        
        document.getElementById('btn-back').style.visibility = step > 1 ? 'visible' : 'hidden';
        if (step === 3) {
          document.getElementById('btn-next').style.display = 'none';
          document.getElementById('btn-submit').style.display = 'inline-block';
        } else {
          document.getElementById('btn-next').style.display = 'inline-block';
          document.getElementById('btn-submit').style.display = 'none';
        }
      }

      function nextStep() {
        const currentInputs = document.querySelectorAll(`#step-${step} input`);
        let valid = true;
        currentInputs.forEach(input => { if(!input.checkValidity()) { input.reportValidity(); valid = false; } });
        if(valid && step < 3) { step++; updateNav(); }
      }

      function prevStep() { if(step > 1) { step--; updateNav(); } }

      async function submitSetup() {
        const form = document.getElementById('setup-form');
        if (!form.checkValidity()) { form.reportValidity(); return; }

        const btn = document.getElementById('btn-submit');
        const loader = document.getElementById('submit-loader');
        const errBox = document.getElementById('error-msg');
        
        btn.disabled = true;
        loader.style.display = 'inline-block';
        document.getElementById('submit-text').innerText = ' Installing...';
        errBox.style.display = 'none';

        const payload = {
          db_host: document.getElementById('db_host').value,
          db_port: document.getElementById('db_port').value,
          db_name: document.getElementById('db_name').value,
          db_user: document.getElementById('db_user').value,
          db_pass: document.getElementById('db_pass').value,
          admin_fname: document.getElementById('admin_fname').value,
          admin_lname: document.getElementById('admin_lname').value,
          admin_email: document.getElementById('admin_email').value,
          admin_pass: document.getElementById('admin_pass').value,
          business_name: document.getElementById('business_name').value,
        };

        try {
          const res = await fetch('/setup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await res.json();
          if (res.ok) {
            document.querySelectorAll('.step-content').forEach(e => e.classList.remove('active'));
            document.getElementById('step-success').classList.add('active');
            document.getElementById('wizard-footer').style.display = 'none';
            document.querySelector('.stepper').style.display = 'none';
          } else {
            errBox.innerText = data.error || 'An error occurred during setup.';
            errBox.style.display = 'block';
            btn.disabled = false;
            loader.style.display = 'none';
            document.getElementById('submit-text').innerText = ' Finish Setup';
          }
        } catch (e) {
          errBox.innerText = 'Network error. Please ensure the server is running.';
          errBox.style.display = 'block';
          btn.disabled = false;
          loader.style.display = 'none';
          document.getElementById('submit-text').innerText = ' Finish Setup';
        }
      }
